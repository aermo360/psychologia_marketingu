---
import { getCollection } from "astro:content";

const STRAPI_URL = process.env.STRAPI_URL || import.meta.env.PUBLIC_STRAPI_URL || "http://localhost:1337";

interface Article {
    title: string;
    slug: string;
    excerpt?: string;
    category?: string;
    author_name?: string;
    featured_image_url?: string;
    featured_image?: any;
    publish_date?: string;
    read_time?: number;
    featured?: boolean;
}

// Only allow http(s) URLs in CSS style attributes to prevent injection
const safeImageUrl = (url?: string | null): string =>
    url && /^https?:\/\//.test(url) ? url : "";

let articles: Article[] = [];
try {
    const strapiArticles = await getCollection("articles");
    if (strapiArticles && strapiArticles.length > 0) {
        articles = strapiArticles.map((a: any) => {
            const data = a.data;
            let imageUrl = data.featured_image_url;
            if (data.featured_image?.url) {
                imageUrl = data.featured_image.url.startsWith("http")
                    ? data.featured_image.url
                    : `${STRAPI_URL}${data.featured_image.url}`;
            }
            return { ...data, featured_image_url: imageUrl };
        });
    }
} catch (e) {
    console.error("[Blog] Could not fetch articles from Strapi:", e);
}

const featuredArticle = articles.find(a => a.featured) || articles[0];
const regularArticles = articles.filter(a => a !== featuredArticle);

const categories = [...new Set(articles.map(a => a.category).filter(Boolean))];

function formatDate(dateStr?: string) {
    if (!dateStr) return "";
    const date = new Date(dateStr);
    return date.toLocaleDateString("pl-PL", { day: "numeric", month: "long", year: "numeric" });
}
---

<!-- Header section -->
<section class="max-w-[1280px] mx-auto px-6 lg:px-20 pt-12 pb-8">
    <div class="border-b border-[#e6dbdb] dark:border-[#3d2a2a] pb-6 flex flex-col md:flex-row justify-between items-end gap-4">
        <div>
            <p class="text-primary font-bold uppercase tracking-widest text-xs mb-2">Blog edukacyjny</p>
            <h1 class="text-3xl lg:text-5xl font-black tracking-tight text-[#181111] dark:text-white">
                Baza wiedzy i aktualności
            </h1>
        </div>
        {categories.length > 0 && (
            <div class="flex gap-2 text-sm font-medium flex-wrap">
                <a class="px-4 py-2 rounded-full bg-primary text-white" href="/blog">Wszystkie</a>
                {categories.map(cat => (
                    <span class="px-4 py-2 rounded-full bg-white dark:bg-white/5 border border-[#e6dbdb] dark:border-[#3d2a2a] hover:border-primary/50 transition-colors cursor-default">{cat}</span>
                ))}
            </div>
        )}
    </div>
</section>

{articles.length === 0 ? (
    <!-- Empty state — no articles yet -->
    <section class="max-w-[1280px] mx-auto px-6 lg:px-20 pb-32 flex flex-col items-center justify-center text-center py-20">
        <div class="size-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-6">
            <span class="material-symbols-outlined text-3xl" aria-hidden="true">edit_note</span>
        </div>
        <h2 class="text-2xl font-bold text-[#181111] dark:text-white mb-3">
            Artykuły już wkrótce
        </h2>
        <p class="text-gray-500 dark:text-gray-400 max-w-md">
            Przygotowujemy dla Ciebie wartościowe treści z zakresu psychologii marketingu.
            Wróć wkrótce!
        </p>
        <a href="/" class="mt-8 inline-flex items-center gap-2 text-primary font-bold hover:gap-3 transition-all">
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span> Wróć na stronę główną
        </a>
    </section>
) : (
    <>
        <!-- Featured article -->
        {featuredArticle && (
        <section class="max-w-[1280px] mx-auto px-6 lg:px-20 pb-12">
            <a href={`/blog/${featuredArticle.slug}`} class="group relative rounded-3xl overflow-hidden bg-white dark:bg-[#1a0c0c] border border-[#e6dbdb] dark:border-[#3d2a2a] shadow-lg hover:shadow-xl transition-all block">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                    <div class="aspect-[16/10] lg:aspect-auto lg:min-h-[400px] w-full overflow-hidden">
                        <div
                            class="h-full w-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
                            style={safeImageUrl(featuredArticle.featured_image_url) ? `background-image: url("${safeImageUrl(featuredArticle.featured_image_url)}");` : ""}
                        ></div>
                    </div>
                    <div class="p-8 lg:p-12 flex flex-col justify-center">
                        <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-wider mb-4">
                            <span class="text-primary">{featuredArticle.category}</span>
                            <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                            <span class="text-gray-500">{formatDate(featuredArticle.publish_date)}</span>
                        </div>
                        <h2 class="text-2xl lg:text-4xl font-black mb-4 leading-tight group-hover:text-primary transition-colors">
                            {featuredArticle.title}
                        </h2>
                        <p class="text-gray-600 dark:text-gray-400 mb-8 line-clamp-3 leading-relaxed">
                            {featuredArticle.excerpt}
                        </p>
                        <div>
                            <span class="inline-flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest group-hover:gap-3 transition-all">
                                Czytaj więcej <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_forward</span>
                            </span>
                        </div>
                    </div>
                </div>
            </a>
        </section>
        )}

        <!-- Articles grid -->
        {regularArticles.length > 0 && (
        <section class="max-w-[1280px] mx-auto px-6 lg:px-20 pb-20">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {regularArticles.map(article => (
                    <article class="flex flex-col group h-full">
                        <a href={`/blog/${article.slug}`} class="block">
                            <div class="aspect-[16/10] rounded-2xl overflow-hidden mb-4 bg-gray-100 dark:bg-gray-800 relative">
                                <div
                                    class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
                                    style={safeImageUrl(article.featured_image_url) ? `background-image: url("${safeImageUrl(article.featured_image_url)}");` : ""}
                                ></div>
                                {article.category && (
                                    <div class="absolute top-4 left-4">
                                        <span class="px-3 py-1 bg-white/90 dark:bg-black/80 backdrop-blur-sm rounded-lg text-xs font-bold uppercase tracking-wider text-primary">{article.category}</span>
                                    </div>
                                )}
                            </div>
                        </a>
                        <div class="flex-1 flex flex-col">
                            <div class="text-xs text-gray-500 font-medium mb-2">{formatDate(article.publish_date)}</div>
                            <a href={`/blog/${article.slug}`}>
                                <h3 class="text-xl font-bold mb-3 leading-tight group-hover:text-primary transition-colors">
                                    {article.title}
                                </h3>
                            </a>
                            <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-2 mb-4">
                                {article.excerpt}
                            </p>
                            <div class="mt-auto pt-4 border-t border-gray-100 dark:border-white/5">
                                <a class="text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all" href={`/blog/${article.slug}`}>
                                    Czytaj dalej <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_right_alt</span>
                                </a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>
        )}
    </>
)}
