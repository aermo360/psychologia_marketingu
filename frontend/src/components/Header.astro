---

---

<header
    class="sticky top-0 z-40 w-full bg-white/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-[#e6dbdb] dark:border-[#3d2a2a]"
>
    <div
        class="max-w-[1280px] mx-auto px-6 lg:px-20 h-16 flex items-center justify-between"
    >
        <a href="/" class="flex items-center">
            <img src="/logo-pwr-color.png" alt="Politechnika Wrocławska" class="h-14 dark:hidden" />
            <img src="/logo-pwr-white.png" alt="Politechnika Wrocławska" class="h-14 hidden dark:block" />
        </a>
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex gap-6">
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/#program">Program</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/wykladowcy/">Wykładowcy</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/#dlaczego">Dlaczego my?</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/blog/">Blog</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/faq/">FAQ</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="#kontakt">Kontakt</a
                >
            </nav>
            <a
                class="bg-primary hover:bg-red-700 text-white px-5 py-2 rounded-lg text-sm font-bold transition-all transform hover:scale-105"
                href="https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PKMP-000P-NNPW2/?from=field:PKM"
                target="_blank"
                rel="noopener noreferrer"
            >
                Rekrutacja
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            id="mobile-menu-button"
            class="md:hidden text-[#181111] dark:text-white p-3 min-w-[44px] min-h-[44px] flex items-center justify-center focus-visible:ring-2 focus-visible:ring-primary outline-none rounded-lg"
            aria-label="Otwórz menu nawigacji"
            aria-expanded="false"
            aria-controls="mobile-menu"
        >
            <span id="menu-icon" class="material-symbols-outlined !text-[32px]" aria-hidden="true"
                >menu</span
            >
        </button>
    </div>
</header>

<!-- Mobile Menu Container -->
<div
    id="mobile-menu"
    class="hidden fixed top-16 left-0 right-0 z-50 bg-white dark:bg-[#1a1a1a] md:hidden overflow-y-auto border-t border-gray-100 dark:border-[#3d2a2a]"
    style="height: calc(100vh - 4rem); height: calc(100dvh - 4rem);"
>
    <div class="flex flex-col p-6 gap-6">
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/#program">Program</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/wykladowcy/">Wykładowcy</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/#dlaczego">Dlaczego my?</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/blog/">Blog</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/faq/">FAQ</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="#kontakt">Kontakt</a
        >

        <a
            class="mt-4 bg-primary text-white py-4 rounded-xl text-xl font-bold shadow-lg shadow-primary/20 block text-center"
            href="https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PKMP-000P-NNPW2/?from=field:PKM"
            target="_blank"
            rel="noopener noreferrer"
        >
            Rekrutacja
        </a>
    </div>
</div>

<script is:inline>
    (function () {
        const btn = document.getElementById("mobile-menu-button");
        const menu = document.getElementById("mobile-menu");
        const menuIcon = document.getElementById("menu-icon");
        const links = document.querySelectorAll(".mobile-link");

        function openMenu() {
            if (menu) {
                menu.classList.remove("hidden");
                document.body.classList.add("overflow-hidden");
                btn.setAttribute("aria-expanded", "true");
                btn.setAttribute("aria-label", "Zamknij menu nawigacji");
                if (menuIcon) menuIcon.textContent = "close";
            }
        }

        function closeMenu() {
            if (menu) {
                menu.classList.add("hidden");
                document.body.classList.remove("overflow-hidden");
                btn.setAttribute("aria-expanded", "false");
                btn.setAttribute("aria-label", "Otwórz menu nawigacji");
                if (menuIcon) menuIcon.textContent = "menu";
            }
        }

        function toggleMenu() {
            const isOpen = btn.getAttribute("aria-expanded") === "true";
            isOpen ? closeMenu() : openMenu();
        }

        if (btn) {
            btn.onclick = (e) => {
                e.preventDefault();
                e.stopPropagation();
                toggleMenu();
            };
        }

        links.forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
    })();
</script>
