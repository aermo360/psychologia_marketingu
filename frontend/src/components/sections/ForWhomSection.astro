---
const personas = [
    { icon: "leaderboard", title: "Menedżerowie marketingu", desc: "Kadra zarządzająca z obszaru marketingu i mediów, która chce opierać strategie na twardej wiedzy o zachowaniach klientów, nie na przeczuciu." },
    { icon: "campaign", title: "Specjaliści marketingu i promocji", desc: "Pracownicy działów marketingu, promocji i komunikacji oraz rzecznicy prasowi, którzy chcą podnieść skuteczność swoich działań." },
    { icon: "label", title: "Brand i product managerowie", desc: "Osoby odpowiedzialne za markę i ofertę, budujące wizerunek i relacje z konsumentem w oparciu o emocje i psychologię." },
    { icon: "business_center", title: "Agencje reklamowe i kreatywne", desc: "Pracownicy agencji, którzy chcą wzmocnić warsztat o psychologię perswazji, neuromarketing i projektowanie doświadczeń." },
    { icon: "group", title: "Specjaliści obsługi klienta", desc: "Osoby pracujące z klientem, dla których zrozumienie motywacji, emocji i procesów decyzyjnych przekłada się na lepsze relacje i sprzedaż." },
    { icon: "trending_up", title: "Właściciele firm i przedsiębiorcy", desc: "Osoby prowadzące własny biznes, które chcą lepiej rozumieć swoich klientów i skuteczniej docierać do nich z ofertą." },
];
const benefits = [
    "Zrozumiesz prawdziwe motywacje zakupowe konsumentów",
    "Zwiększysz skuteczność strategii marketingowych i reklamowych",
    "Nauczysz się budować lojalność i zaufanie do marki",
    "Zaprojektujesz doświadczenia klienta (CX) oparte na danych",
];
const irk = "https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PKMP-000P-NNPW2/?from=field:PKM";
---

<section class="max-w-[1280px] mx-auto px-6 lg:px-20 pt-16 pb-8">
    <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a class="hover:text-primary" href="/">Strona główna</a>
        <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span>
        <span class="text-gray-900 dark:text-white font-medium" aria-current="page">Dla kogo</span>
    </nav>
    <div class="max-w-3xl">
        <div class="flex items-center gap-2 mb-4">
            <span class="h-1 w-12 bg-primary rounded-full"></span>
            <p class="text-primary text-sm font-bold tracking-widest uppercase">Adresaci studiów</p>
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-[#181111] dark:text-white tracking-tight mb-5">
            Studia podyplomowe z marketingu dla menedżerów i specjalistów
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
            Studia <strong class="text-[#181111] dark:text-white">Psychologia komunikacji marketingowej
            i zachowań konsumenckich</strong> adresowane są do osób pełniących funkcje marketingowe lub
            przygotowujących się do tej roli — od specjalistów po kadrę menedżerską. Jeśli chcesz rozumieć
            konsumenta głębiej i podejmować decyzje w oparciu o wiedzę, te studia są dla Ciebie.
        </p>
    </div>
</section>

<!-- Persony -->
<section class="max-w-[1280px] mx-auto px-6 lg:px-20 py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {personas.map((p) => (
            <div class="bg-white dark:bg-[#1a0c0c] border border-[#e6dbdb] dark:border-[#3d2a2a] rounded-xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
                <span class="material-symbols-outlined text-primary text-3xl mb-3" aria-hidden="true">{p.icon}</span>
                <h2 class="text-lg font-bold mb-2 text-[#181111] dark:text-white">{p.title}</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{p.desc}</p>
            </div>
        ))}
    </div>
</section>

<!-- Co zyskasz -->
<section class="py-16 bg-primary/5 dark:bg-primary/10 mt-8">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
            <h2 class="text-3xl font-black mb-6 text-[#181111] dark:text-white">Co zyskasz</h2>
            <ul class="space-y-4">
                {benefits.map((b) => (
                    <li class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary mt-0.5" aria-hidden="true">check_circle</span>
                        <p class="text-base font-medium text-gray-700 dark:text-gray-200">{b}</p>
                    </li>
                ))}
            </ul>
        </div>
        <div class="bg-white dark:bg-[#1a0c0c] rounded-2xl p-8 border border-[#e6dbdb] dark:border-[#3d2a2a] flex flex-col gap-5">
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
                Niezależnie od tego, czy zarządzasz zespołem, czy dopiero wchodzisz w marketing —
                program da Ci wspólny język psychologii i biznesu oraz praktyczne narzędzia do pracy
                z konsumentem.
            </p>
            <div class="flex flex-col gap-3">
                <a class="bg-primary hover:bg-red-700 text-white px-8 py-3 rounded-lg font-bold text-center transition-all hover:scale-[1.02] shadow-lg shadow-primary/20" href={irk} target="_blank" rel="noopener noreferrer">Zapisz się na studia (IRK)</a>
                <a class="border border-primary/30 text-primary hover:bg-primary/5 px-8 py-3 rounded-lg font-bold text-center transition-all" href="/program/">Zobacz program studiów</a>
            </div>
        </div>
    </div>
</section>
