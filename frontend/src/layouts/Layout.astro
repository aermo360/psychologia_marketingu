---
interface Props {
	title: string;
	description?: string;
	image?: string;
}

import "../styles/global.css";

const {
	title,
	description = "Studia podyplomowe z praktycznego e-marketingu na Politechnice Wrocławskiej. Zdobądź nowoczesne kompetencje w marketingu cyfrowym od czołowych ekspertów z branży.",
	image = "https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=1200&auto=format&fit=crop"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "http://praktycznymarketing.edu.pl");
---

<!doctype html>
<html class="light" lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="pl_PL" />
		<meta property="og:site_name" content="Praktyczny e-marketing - PWr" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Fonts with optimized loading -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght@20..48,400&display=block"
			rel="stylesheet"
		/>

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "EducationalOrganization",
				"name": "Politechnika Wrocławska - Studia Podyplomowe E-marketing",
				"url": "http://praktycznymarketing.edu.pl",
				"logo": "http://praktycznymarketing.edu.pl/favicon.svg",
				"description": "Studia podyplomowe z praktycznego e-marketingu",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "ul. Na Grobli 15",
					"addressLocality": "Wrocław",
					"postalCode": "50-421",
					"addressCountry": "PL"
				},
				"contactPoint": {
					"@type": "ContactPoint",
					"telephone": "+48 71 340 75 15",
					"email": "anna.fafara@pwr.edu.pl",
					"contactType": "Admissions"
				}
			}
		</script>

		<style is:global>
			.material-symbols-outlined {
				font-variation-settings:
					"FILL" 0,
					"wght" 400,
					"GRAD" 0,
					"opsz" 24;
			}
			body {
				font-family: "Inter", sans-serif;
			}
		</style>
	</head>
	<body
		class="bg-background-light dark:bg-background-dark text-[#181111] dark:text-white transition-colors duration-200"
	>
		<slot />
	</body>
</html>
