---
import { getCollection } from "astro:content";

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL || "http://localhost:1337";
let lecturers: any[] = [];

try {
    const strapiLecturers = await getCollection("lecturers");
    if (strapiLecturers && strapiLecturers.length > 0) {
        lecturers = strapiLecturers
            .map((l: any) => {
                const data = l.data;
                let finalImageUrl = data.image_url;

                if (data.image?.url) {
                    finalImageUrl = data.image.url.startsWith("http")
                        ? data.image.url
                        : `${STRAPI_URL}${data.image.url}`;
                }

                return {
                    ...data,
                    finalImageUrl,
                };
            })
            .sort((a: any, b: any) => (a.order || 99) - (b.order || 99));
    }
} catch (e) {
    console.warn("Could not fetch lecturers from Strapi.");
}

// Structured data: list of lecturers as schema.org Person items
const lecturersJsonLd = lecturers.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Wykładowcy studiów podyplomowych Psychologia komunikacji marketingowej",
    "itemListElement": lecturers.map((lecturer: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
            "@type": "Person",
            "name": lecturer.name,
            "jobTitle": lecturer.role,
            ...(lecturer.description ? { "description": lecturer.description } : {}),
            ...((lecturer.finalImageUrl || lecturer.image_url) ? { "image": lecturer.finalImageUrl || lecturer.image_url } : {}),
            "worksFor": {
                "@type": "EducationalOrganization",
                "@id": "https://psychologiamarketingu.edu.pl/#organization",
            },
        },
    })),
} : null;
---

{lecturersJsonLd && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(lecturersJsonLd)} />
)}

<div class="w-full py-10 md:py-16" id="wykladowcy">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-20 flex flex-col flex-1">
        <!-- PageHeading -->
        <div class="flex flex-col gap-3 mb-12">
            <div class="flex items-center gap-2">
                <span class="h-1 w-12 bg-primary rounded-full"></span>
                <p
                    class="text-primary text-sm font-bold tracking-widest uppercase"
                >
                    Eksperci: doświadczeni praktycy i dydaktycy
                </p>
            </div>
            <h1
                class="text-[#181111] dark:text-white text-4xl md:text-5xl font-black leading-tight tracking-[-0.033em]"
            >
                Wykładowcy studiów podyplomowych z psychologii marketingu
            </h1>
            <div class="text-[#896161] dark:text-[#b59a9a] text-lg font-normal leading-relaxed max-w-3xl space-y-4">
                <p>
                    Siłą studiów podyplomowych <strong class="text-[#181111] dark:text-white font-semibold">Psychologia
                    komunikacji marketingowej i zachowań konsumenckich</strong> jest kadra, która
                    łączy dwie perspektywy: akademicką rzetelność nauczycieli Wydziału Zarządzania
                    Politechniki Wrocławskiej oraz codzienne doświadczenie czynnych praktyków
                    marketingu, badaczy rynku i specjalistów komunikacji. Dzięki temu wiedza
                    z zakresu psychologii konsumenta, neuromarketingu, perswazyjności reklamy
                    i projektowania doświadczeń (CX) jest przekazywana nie jako sucha teoria,
                    lecz w bezpośrednim odniesieniu do realnych kampanii, marek i decyzji biznesowych.
                </p>
                <p>
                    Opiekę merytoryczną nad programem sprawuje kierownik studiów
                    <strong class="text-[#181111] dark:text-white font-semibold">dr Mirosława Krzyścin</strong>,
                    a poszczególne przedmioty prowadzą eksperci specjalizujący się w swoich
                    dziedzinach — od psychologii sprzedaży i technik wpływu, przez storytelling,
                    content marketing i emocjonalny branding, po badania zachowań konsumenckich
                    oraz wykorzystanie sztucznej inteligencji w poznawaniu klienta.
                </p>
            </div>
            <ul class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mt-2">
                <li class="bg-white dark:bg-background-dark/40 border border-[#f4f0f0] dark:border-[#3d2a2a] rounded-xl p-5">
                    <p class="text-primary font-bold text-sm mb-1">Nauka + biznes</p>
                    <p class="text-sm text-[#896161] dark:text-[#b59a9a]">Wykładowcy akademiccy PWr i czynni praktycy w jednym zespole.</p>
                </li>
                <li class="bg-white dark:bg-background-dark/40 border border-[#f4f0f0] dark:border-[#3d2a2a] rounded-xl p-5">
                    <p class="text-primary font-bold text-sm mb-1">Zajęcia w praktyce</p>
                    <p class="text-sm text-[#896161] dark:text-[#b59a9a]">Wykłady aktywizujące, studia przypadków, warsztaty i ćwiczenia.</p>
                </li>
                <li class="bg-white dark:bg-background-dark/40 border border-[#f4f0f0] dark:border-[#3d2a2a] rounded-xl p-5">
                    <p class="text-primary font-bold text-sm mb-1">Szeroka ekspertyza</p>
                    <p class="text-sm text-[#896161] dark:text-[#b59a9a]">Psychologia konsumenta, neuromarketing, CX, branding, badania, AI.</p>
                </li>
            </ul>
        </div>
        <!-- ImageGrid / Teacher Cards -->
        {lecturers.length === 0 ? (
            <div class="mb-16 py-16 text-center border border-dashed border-[#e6dbdb] dark:border-[#3d2a2a] rounded-2xl">
                <span class="material-symbols-outlined text-4xl text-gray-300 dark:text-gray-700 mb-3 block" aria-hidden="true">group</span>
                <p class="text-gray-500 dark:text-gray-400">Profile wykładowców pojawią się wkrótce.</p>
            </div>
        ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {
                lecturers.map((lecturer: any) => (
                    <div class="flex flex-col gap-4 p-5 bg-white dark:bg-background-dark/40 rounded-xl border border-[#f4f0f0] dark:border-[#3d2a2a] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all">
                        <div class="w-full aspect-[4/5] rounded-lg overflow-hidden md:grayscale hover:grayscale-0 transition-all duration-500">
                            <img
                                src={lecturer.finalImageUrl || lecturer.image_url}
                                alt={`${lecturer.name} - ${lecturer.role}`}
                                class="w-full h-full object-cover"
                                width="400"
                                height="500"
                                loading="lazy"
                            />
                        </div>
                        <div class="flex flex-col gap-1">
                            <div class="flex justify-between items-start">
                                <p class="text-primary text-xl font-bold leading-tight">
                                    {lecturer.name}
                                </p>
                            </div>
                            <p class="text-[#181111] dark:text-white text-sm font-semibold uppercase tracking-wider">
                                {lecturer.role}
                            </p>
                            <p class="text-[#896161] dark:text-[#b59a9a] text-sm font-normal leading-normal mt-2">
                                {lecturer.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
        )}
        <!-- CTASection -->
        <div
            class="rounded-2xl overflow-hidden bg-primary/5 dark:bg-primary/10 border border-primary/20 p-8 md:p-12 mb-16"
        >
            <div class="flex flex-col items-center gap-6 text-center">
                <h2
                    class="text-[#181111] dark:text-white text-3xl md:text-4xl font-black leading-tight tracking-tight max-w-[720px]"
                >
                    Zacznij swoją karierę w marketingu behawioralnym
                </h2>
                <p
                    class="text-[#896161] dark:text-[#b59a9a] text-lg font-normal leading-normal max-w-[600px]"
                >
                    Rekrutacja na studia podyplomowe właśnie trwa. Zdobądź
                    certyfikat renomowanej uczelni technicznej i dołącz do grona
                    profesjonalistów.
                </p>
                <a
                    class="flex min-w-[180px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-8 bg-primary text-white text-base font-bold leading-normal tracking-[0.015em] hover:scale-105 transition-all shadow-lg shadow-primary/20"
                    href="https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PKMP-000P-NNPW2/?from=field:PKM"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <span class="truncate">Zapisz się teraz</span>
                </a>
            </div>
        </div>
    </div>
</div>
