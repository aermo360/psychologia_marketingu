---

---

<section id="program" class="max-w-[1280px] mx-auto px-6 lg:px-20 py-16">
    <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight">Program studiów</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-2">Kompleksowe moduły opracowane przez ekspertów akademickich i praktyków MARKETINGU</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <!-- Psychologia w marketingu - pełna szerokość z obrazkiem -->
        <div class="md:col-span-12 bg-white dark:bg-[#1a0c0c] border border-[#e6dbdb] dark:border-[#3d2a2a] rounded-2xl p-8 flex flex-col justify-between group hover:border-primary transition-all shadow-sm overflow-hidden">
            <div class="flex flex-col md:flex-row gap-8 items-start">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-primary text-4xl" aria-hidden="true">neurology</span>
                        <h3 class="text-2xl font-bold">Psychologia w marketingu</h3>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 mb-6">Fundamenty zachowań konsumenckich oparte na biologii i ewolucji.</p>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div class="bg-background-light dark:bg-background-dark/40 p-4 rounded-lg">
                            <p class="font-bold text-sm text-primary mb-1">Psychologia perswazji</p>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Klasyczna koncepcja wpływu społecznego.</p>
                        </div>
                        <div class="bg-background-light dark:bg-background-dark/40 p-4 rounded-lg">
                            <p class="font-bold text-sm text-primary mb-1">Psychologia konsumenta</p>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Psychologia sprzedaży i negocjacji.</p>
                        </div>
                        <div class="bg-background-light dark:bg-background-dark/40 p-4 rounded-lg">
                            <p class="font-bold text-sm text-primary mb-1">Psychologia stosowana</p>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Psychologia reklamy i mediów.</p>
                        </div>
                    </div>
                </div>
                <div class="w-full md:w-56 h-40 bg-gray-100 dark:bg-background-dark/40 rounded-lg overflow-hidden shrink-0">
                    <img src="https://images.unsplash.com/photo-1551836022-deb4988cc6c0?q=80&w=400&auto=format&fit=crop" alt="Psychologia w marketingu" class="w-full h-full object-cover" />
                </div>
            </div>
            <div class="mt-6 flex justify-end">
                <span class="text-xs font-bold uppercase tracking-widest text-gray-400">Moduł I</span>
            </div>
        </div>
        <!-- Rząd: Badania i analiza + Komunikacja + Marketing behawioralny -->
        <div class="md:col-span-4 bg-[#221010] text-white rounded-2xl p-8 flex flex-col justify-between hover:scale-[1.02] transition-all shadow-xl">
            <div>
                <span class="material-symbols-outlined text-primary text-4xl mb-4" aria-hidden="true">analytics</span>
                <h3 class="text-2xl font-bold mb-2">Badania i analiza</h3>
                <p class="text-white/70 text-sm mb-4">Metody badawcze i analiza zachowań konsumenckich.</p>
            </div>
            <ul class="space-y-2 text-sm">
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Badanie zachowań konsumenckich</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Consumer insights</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Nowoczesne trendy konsumenckie</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Poszukiwanie wzrostu (growth marketing)</li>
            </ul>
            <div class="mt-6">
                <span class="text-xs font-bold uppercase tracking-widest text-primary">Moduł II</span>
            </div>
        </div>
        <div class="md:col-span-4 bg-primary text-white rounded-2xl p-8 flex flex-col justify-between hover:scale-[1.02] transition-all shadow-xl">
            <div>
                <span class="material-symbols-outlined text-white text-4xl mb-4" aria-hidden="true">history_edu</span>
                <h3 class="text-2xl font-bold mb-2">Komunikacja</h3>
                <p class="text-white/90 text-sm mb-4">Prosty język, etyczna perswazja i storytelling.</p>
            </div>
            <ul class="space-y-2 text-sm">
                <li class="flex gap-2"><span class="text-white/60">&#9679;</span> Trening umiejętności komunikacyjnych</li>
                <li class="flex gap-2"><span class="text-white/60">&#9679;</span> Autoprezentacja i wystąpienia publiczne</li>
            </ul>
            <div class="mt-6">
                <span class="text-xs font-bold uppercase tracking-widest text-white/60">Moduł III</span>
            </div>
        </div>
        <div class="md:col-span-4 bg-[#221010] text-white rounded-2xl p-8 flex flex-col justify-between hover:scale-[1.02] transition-all shadow-xl">
            <div>
                <span class="material-symbols-outlined text-primary text-4xl mb-4" aria-hidden="true">psychology</span>
                <h3 class="text-2xl font-bold mb-2">Marketing behawioralny</h3>
                <p class="text-white/70 text-sm mb-4">Mechanizmy wpływające na decyzje konsumenckie.</p>
            </div>
            <ul class="space-y-2 text-sm">
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Promocje konsumenckie</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Perswazyjność reklamy</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Motywacje konsumenckie</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Zachowania nabywcze</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> CSR i wpływ na decyzje</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Emocjonalny branding</li>
                <li class="flex gap-2"><span class="text-primary">&#9679;</span> Nowe media i relacje z konsumentem</li>
            </ul>
            <div class="mt-6">
                <span class="text-xs font-bold uppercase tracking-widest text-primary">Moduł IV</span>
            </div>
        </div>
        <!-- CX Design - pełna szerokość -->
        <div class="md:col-span-12 bg-white dark:bg-[#1a0c0c] border border-[#e6dbdb] dark:border-[#3d2a2a] rounded-2xl p-8 flex flex-col justify-between group hover:border-primary transition-all shadow-sm overflow-hidden">
            <div class="flex flex-col md:flex-row gap-8 items-start">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-primary text-4xl" aria-hidden="true">frame_inspect</span>
                        <h3 class="text-2xl font-bold">CX Design</h3>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 mb-6">Projektowanie doświadczeń klienta i service design na najwyższym poziomie.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold">User Experience</span>
                        <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold">Service Design</span>
                        <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold">Prototyping</span>
                        <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold">Mapa podróży klienta</span>
                        <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold">Trening kreatywnego myślenia</span>
                    </div>
                </div>
                <div class="w-full md:w-56 h-40 bg-gray-100 dark:bg-background-dark/40 rounded-lg overflow-hidden shrink-0">
                    <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?q=80&w=400&auto=format&fit=crop" alt="Koszyk zakupowy" class="w-full h-full object-cover" />
                </div>
            </div>
            <div class="mt-6 flex justify-end">
                <span class="text-xs font-bold uppercase tracking-widest text-gray-400">Moduł V</span>
            </div>
        </div>
    </div>
    <div class="text-center mt-10">
        <a class="inline-flex items-center gap-2 text-primary font-bold hover:gap-3 transition-all" href="/program/">
            Zobacz pełny plan studiów — 25 przedmiotów i 76 ECTS
            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
    </div>
</section>
