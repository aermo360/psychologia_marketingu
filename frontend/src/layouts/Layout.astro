---
interface Props {
	title: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";

const {
	title,
	description = "Studia podyplomowe z praktycznego e-marketingu na Politechnice Wrocławskiej. Zdobądź nowoczesne kompetencje w marketingu cyfrowym od czołowych ekspertów z branży.",
	image = "https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=1200&auto=format&fit=crop",
	noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://praktycznymarketing.edu.pl");
---

<!doctype html>
<html class="light" lang="pl">
	<head>
		<!-- Theme detection: run before paint to avoid flash -->
		<script is:inline>
			(function(){var t=localStorage.getItem("theme");if(t==="dark"||(!t&&window.matchMedia("(prefers-color-scheme: dark)").matches)){document.documentElement.classList.replace("light","dark")}})();
		</script>

		<!-- Google Analytics Consent Mode v2 — default denied until user accepts -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag("consent", "default", {
				analytics_storage: "denied",
				wait_for_update: 500
			});
			// Restore consent if user previously accepted
			if (typeof localStorage !== "undefined" && localStorage.getItem("cookie_consent") === "granted") {
				gtag("consent", "update", { analytics_storage: "granted" });
			}
		</script>
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KJ5FY3DR7Q"></script>
		<script is:inline>
			gtag("js", new Date());
			gtag("config", "G-KJ5FY3DR7Q");
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="pl_PL" />
		<meta property="og:site_name" content="Praktyczny e-marketing - PWr" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Material Symbols (icon subset only — reduces payload ~90%) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=arrow_forward,arrow_right_alt,calendar_today,call,campaign,check,check_circle,chevron_right,close,dark_mode,insights,label,leaderboard,light_mode,link,location_on,mail,menu,person,schedule,school,share,smart_toy,social_leaderboard,trending_up&display=block"
			rel="stylesheet"
		/>

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "EducationalOrganization",
				"@id": "https://praktycznymarketing.edu.pl/#organization",
				"name": "Politechnika Wrocławska - Studia Podyplomowe E-marketing",
				"url": "https://praktycznymarketing.edu.pl",
				"logo": "https://praktycznymarketing.edu.pl/favicon.png",
				"description": "Studia podyplomowe z praktycznego e-marketingu",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "ul. Na Grobli 15",
					"addressLocality": "Wrocław",
					"postalCode": "50-421",
					"addressCountry": "PL"
				},
				"contactPoint": {
					"@type": "ContactPoint",
					"telephone": "+48 71 340 75 15",
					"email": "anna.fafara@pwr.edu.pl",
					"contactType": "Admissions"
				}
			}
		</script>

		<style is:global>
			.material-symbols-outlined {
				font-variation-settings:
					"FILL" 0,
					"wght" 400,
					"GRAD" 0,
					"opsz" 24;
			}
			body {
				font-family: "Inter Variable", "Inter", sans-serif;
			}
		</style>
	</head>
	<body
		class="bg-background-light dark:bg-background-dark text-[#181111] dark:text-white transition-colors duration-200"
	>
		<slot />
		<CookieBanner />
	</body>
</html>
