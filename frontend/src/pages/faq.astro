---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FaqSection from "../components/sections/FaqSection.astro";

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://psychologiamarketingu.edu.pl/" },
        { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://psychologiamarketingu.edu.pl/faq/" },
    ],
};
---

<Layout
    title="FAQ - Psychologia komunikacji marketingowej | Politechnika Wrocławska"
    description="Najczęściej zadawane pytania o studia podyplomowe Psychologia komunikacji marketingowej na PWr — rekrutacja, wymagane dokumenty, opłaty (7600 zł), tryb online i czas trwania."
    jsonLd={breadcrumbs}
>
    <Header />
    <main id="main-content" class="flex-1">
        <FaqSection />
    </main>
    <Footer />
</Layout>
