---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AdmissionsSection from "../components/sections/AdmissionsSection.astro";

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://psychologiamarketingu.edu.pl/" },
        { "@type": "ListItem", "position": 2, "name": "Rekrutacja", "item": "https://psychologiamarketingu.edu.pl/rekrutacja/" },
    ],
};
---

<Layout
    title="Rekrutacja — studia podyplomowe PWr | Psychologia marketingu"
    description="Rekrutacja na studia podyplomowe Psychologia komunikacji marketingowej na Politechnice Wrocławskiej: wymagania, proces zapisu krok po kroku, opłaty (7600 zł) i kontakt. Edycja 2026/2027."
    jsonLd={breadcrumbs}
>
    <Header />
    <main id="main-content" class="flex-1">
        <AdmissionsSection />
    </main>
    <Footer />
</Layout>
