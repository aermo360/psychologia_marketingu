            <div
                class="flex-1 min-w-[150px] px-6 py-6 border-b md:border-b-0 md:border-r border-[#e6dbdb] dark:border-[#3d2a2a]"
            >
                <p
                    class="text-gray-500 dark:text-gray-400 text-sm font-medium mb-1 flex items-center justify-center md:justify-start gap-2"
                >
                    <span class="material-symbols-outlined text-primary text-lg"
