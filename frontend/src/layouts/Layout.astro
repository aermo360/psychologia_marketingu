---
interface Props {
	title: string;
	description?: string;
	image?: string;
	noindex?: boolean;
	jsonLd?: Record<string, any> | Record<string, any>[];
}

import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";

const {
	title,
	description = "Studia podyplomowe Psychologia komunikacji marketingowej i zachowań konsumenckich na Politechnice Wrocławskiej. Marketing behawioralny oparty na wiedzy, nie intuicji.",
	image = "https://psychologiamarketingu.edu.pl/og-default.png",
	noindex = false,
	jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://psychologiamarketingu.edu.pl");

// Resolve OG image to an absolute URL (social crawlers require it)
const imageURL = new URL(image, Astro.site || "https://psychologiamarketingu.edu.pl").href;

// Page-specific structured data passed in by individual pages (Course, BreadcrumbList, etc.)
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html class="light" lang="pl">
	<head>
		<!-- Theme detection: run before paint to avoid flash -->
		<script is:inline>
			(function(){var t=localStorage.getItem("theme");if(t==="dark"||(!t&&window.matchMedia("(prefers-color-scheme: dark)").matches)){document.documentElement.classList.replace("light","dark")}})();
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="pl_PL" />
		<meta property="og:site_name" content="Psychologia komunikacji marketingowej - PWr" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={imageURL} />

		<!-- Inter: Bunny Fonts (EU-hosted, GDPR-compliant, no user consent required) -->
		<link rel="preconnect" href="https://fonts.bunny.net" />
		<link
			href="https://fonts.bunny.net/css?family=inter:400,500,700,900&display=swap"
			rel="stylesheet"
		/>
		<!-- Material Symbols (icon subset — loaded async to avoid render-blocking) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=ads_click,analytics,arrow_back,arrow_forward,arrow_right_alt,article,business_center,calendar_today,call,campaign,check,check_circle,chevron_right,close,cookie,dark_mode,edit_note,expand_more,frame_inspect,group,help_center,history_edu,insights,label,laptop_mac,leaderboard,light_mode,link,location_on,mail,menu,neurology,person,psychology,schedule,school,share,smart_toy,social_leaderboard,trending_up,videocam,workspace_premium&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=ads_click,analytics,arrow_back,arrow_forward,arrow_right_alt,article,business_center,calendar_today,call,campaign,check,check_circle,chevron_right,close,cookie,dark_mode,edit_note,expand_more,frame_inspect,group,help_center,history_edu,insights,label,laptop_mac,leaderboard,light_mode,link,location_on,mail,menu,neurology,person,psychology,schedule,school,share,smart_toy,social_leaderboard,trending_up,videocam,workspace_premium&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "EducationalOrganization",
				"@id": "https://psychologiamarketingu.edu.pl/#organization",
				"name": "Politechnika Wrocławska - Psychologia komunikacji marketingowej",
				"parentOrganization": "Wydział Zarządzania Politechniki Wrocławskiej",
				"url": "https://psychologiamarketingu.edu.pl/",
				"logo": "https://psychologiamarketingu.edu.pl/favicon.png",
				"description": "Studia podyplomowe z psychologii komunikacji marketingowej i zachowań konsumenckich",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "ul. Łukasiewicza 5",
					"postalCode": "50-372",
					"addressLocality": "Wrocław",
					"addressCountry": "PL"
				},
				"contactPoint": {
					"@type": "ContactPoint",
					"telephone": "+48 71 340 75 15",
					"email": "anna.fafara@pwr.edu.pl",
					"contactType": "Admissions"
				}
			}
		</script>

		<!-- Page-specific Structured Data (Course, FAQPage, BreadcrumbList, Person, …) -->
		{jsonLdBlocks.map((block) => (
			<script type="application/ld+json" is:inline set:html={JSON.stringify(block)} />
		))}

		<!-- Google Analytics loaded conditionally after cookie consent (see CookieBanner component) -->

		<style is:global>
			.material-symbols-outlined {
				font-variation-settings:
					"FILL" 0,
					"wght" 400,
					"GRAD" 0,
					"opsz" 24;
			}
			body {
				font-family: "Inter Variable", "Inter", sans-serif;
			}
		</style>
	</head>
	<body
		class="bg-background-light dark:bg-background-dark text-[#181111] dark:text-white transition-colors duration-200"
	>
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:text-sm focus:font-bold">Przejdź do treści</a>
		<slot />
		<CookieBanner />
	</body>
</html>
