<footer
    class="bg-white dark:bg-[#1a0c0c] border-t border-[#e6dbdb] dark:border-[#3d2a2a] pt-20 pb-10"
    id="kontakt"
>
    <div class="max-w-[1280px] mx-auto px-6 lg:px-20">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16"
        >
            <div class="col-span-1 lg:col-span-1">
                <div class="mb-6">
                    <img src="/logo-pwr-color.png" alt="Politechnika Wrocławska" class="h-10 dark:hidden" />
                    <img src="/logo-pwr-white.png" alt="Politechnika Wrocławska" class="h-10 hidden dark:block" />
                </div>
                <p class="text-gray-500 text-sm leading-relaxed">
                    Dział Kształcenia<br />
                    bud. L-1, ul. Na Grobli 15<br />
                    50-421 Wrocław
                </p>
            </div>
            <div>
                <h4
                    class="font-bold mb-6 text-sm uppercase tracking-widest text-primary"
                >
                    Rekrutacja
                </h4>
                <ul class="space-y-4">
                    <li>
                        <a
                            class="text-gray-600 dark:text-gray-400 hover:text-primary text-sm transition-colors"
                            href="/faq/">Wymagane dokumenty</a>
                    </li>
                    <li>
                        <a
                            class="text-gray-600 dark:text-gray-400 hover:text-primary text-sm transition-colors"
                            href="/faq/">Opłaty za studia</a>
                    </li>
                    <li>
                        <a
                            class="text-gray-600 dark:text-gray-400 hover:text-primary text-sm transition-colors"
                            href="https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PKMP-000P-NNPW2/?from=field:PKM" target="_blank" rel="noopener noreferrer">Zapisz się (IRK)</a>
                    </li>
                    <li>
                        <a
                            class="text-gray-600 dark:text-gray-400 hover:text-primary text-sm transition-colors"
                            href="/faq/">FAQ</a>
                    </li>
                </ul>
            </div>
            <div>
                <h4
                    class="font-bold mb-6 text-sm uppercase tracking-widest text-primary"
                >
                    Kontakt
                </h4>
                <ul class="space-y-4 text-sm text-gray-600 dark:text-gray-400">
                    <li class="flex items-center gap-3">
                        <span
                            class="material-symbols-outlined text-primary text-lg"
                            aria-hidden="true"
                            >person</span
                        >
                        Anna Fąfara
                    </li>
                    <li class="flex items-center gap-3">
                        <span
                            class="material-symbols-outlined text-primary text-lg"
                            aria-hidden="true"
                            >mail</span
                        >
                        <a class="hover:text-primary transition-colors" href="mailto:anna.fafara@pwr.edu.pl">anna.fafara@pwr.edu.pl</a>
                    </li>
                    <li class="flex items-center gap-3">
                        <span
                            class="material-symbols-outlined text-primary text-lg"
                            aria-hidden="true"
                            >call</span
                        >
                        tel. 71 340 75 15
                    </li>
                    <li class="flex items-center gap-3">
                        <span
                            class="material-symbols-outlined text-primary text-lg"
                            aria-hidden="true"
                            >location_on</span
                        >
                        bud. L-1, pok. 120
                    </li>
                </ul>
            </div>
            <div>
                <h4
                    class="font-bold mb-6 text-sm uppercase tracking-widest text-primary"
                >
                    Obserwuj nas
                </h4>
                <div class="flex gap-4">
                    <a
                        class="size-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all"
                        href="#"
                        aria-label="LinkedIn"
                    >
                        <span class="material-symbols-outlined" aria-hidden="true"
                            >social_leaderboard</span
                        >
                    </a>
                    <a
                        class="size-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all"
                        href="#"
                        aria-label="Udostępnij"
                    >
                        <span class="material-symbols-outlined" aria-hidden="true">share</span>
                    </a>
                    <a
                        class="size-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all"
                        href="#"
                        aria-label="Skopiuj link"
                    >
                        <span class="material-symbols-outlined" aria-hidden="true">link</span>
                    </a>
                </div>
            </div>
        </div>
        <div
            class="border-t border-[#e6dbdb] dark:border-[#3d2a2a] pt-10 flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <p class="text-xs text-gray-500">
                &copy; 2026 Politechnika Wrocławska. Wszystkie prawa zastrzeżone.
            </p>
            <div class="flex items-center gap-6">
                <a class="text-xs text-gray-500 hover:text-primary" href="/polityka-prywatnosci/"
                    >Polityka prywatności</a
                >
                <a class="text-xs text-gray-500 hover:text-primary" href="/sitemap-index.xml"
                    >Mapa strony</a
                >
                <button
                    id="theme-toggle"
                    class="flex items-center gap-1.5 text-xs text-gray-500 hover:text-primary transition-colors cursor-pointer"
                    aria-label="Przełącz motyw"
                >
                    <span id="theme-icon" class="material-symbols-outlined !text-sm" aria-hidden="true">dark_mode</span>
                    <span id="theme-label">Ciemny</span>
                </button>
            </div>
        </div>
    </div>
</footer>

<script is:inline>
    (function () {
        const html = document.documentElement;
        const saved = localStorage.getItem("theme");
        if (saved === "dark" || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            html.classList.replace("light", "dark");
        }
        updateToggleUI();

        const btn = document.getElementById("theme-toggle");
        if (btn) {
            btn.addEventListener("click", function () {
                const isDark = html.classList.contains("dark");
                if (isDark) {
                    html.classList.replace("dark", "light");
                    localStorage.setItem("theme", "light");
                } else {
                    html.classList.replace("light", "dark");
                    localStorage.setItem("theme", "dark");
                }
                updateToggleUI();
            });
        }

        function updateToggleUI() {
            const icon = document.getElementById("theme-icon");
            const label = document.getElementById("theme-label");
            const isDark = html.classList.contains("dark");
            if (icon) icon.textContent = isDark ? "light_mode" : "dark_mode";
            if (label) label.textContent = isDark ? "Jasny" : "Ciemny";
        }
    })();
</script>
