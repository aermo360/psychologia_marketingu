---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BlogArchive from "../../components/sections/BlogArchive.astro";

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://psychologiamarketingu.edu.pl/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://psychologiamarketingu.edu.pl/blog/" },
    ],
};
---

<Layout
    title="Blog | Psychologia komunikacji marketingowej - Politechnika Wrocławska"
    description="Blog o psychologii marketingu, neuromarketingu i zachowaniach konsumenckich — wiedza i analizy zespołu studiów podyplomowych Politechniki Wrocławskiej."
    jsonLd={breadcrumbs}
>
    <Header />
    <main id="main-content" class="flex-1">
        <BlogArchive />
    </main>
    <Footer />
</Layout>
