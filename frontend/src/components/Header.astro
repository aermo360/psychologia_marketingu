---

---

<header
    class="sticky top-0 z-40 w-full bg-white/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-[#e6dbdb] dark:border-[#3d2a2a]"
>
    <div
        class="max-w-[1280px] mx-auto px-6 lg:px-20 h-16 flex items-center justify-between"
    >
        <a href="/" class="flex items-center">
            <img src="/logo-pwr-color.png" alt="Politechnika Wrocławska" class="h-14 dark:hidden" />
            <img src="/logo-pwr-white.png" alt="Politechnika Wrocławska" class="h-14 hidden dark:block" />
        </a>
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex gap-6">
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/#program">Program</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/wykladowcy">Wykładowcy</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/#rekrutacja">Rekrutacja</a
                >
                <span class="relative">
                    <span
                        class="text-sm font-medium text-gray-400 dark:text-gray-600 cursor-default"
                    >Blog</span>
                    <span class="absolute -top-3 -right-6 bg-primary text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full leading-none">wkr&oacute;tce</span>
                </span>
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="/faq">FAQ</a
                >
                <a
                    class="text-sm font-medium hover:text-primary transition-colors"
                    href="#kontakt">Kontakt</a
                >
            </nav>
            <a
                class="bg-primary hover:bg-red-700 text-white px-5 py-2 rounded-lg text-sm font-bold transition-all transform hover:scale-105"
                href="https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PEMP-000P-NNPW2/?from=field:PEM"
                target="_blank"
                rel="noopener"
            >
                Zapisz się
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            id="mobile-menu-button"
            class="md:hidden text-[#181111] dark:text-white p-2"
            aria-label="Toggle Menu"
        >
            <span id="menu-icon" class="material-symbols-outlined !text-[32px]"
                >menu</span
            >
        </button>
    </div>
</header>

<!-- Mobile Menu Container (Moved outside Header to avoid stacking context issues) -->
<div
    id="mobile-menu"
    class="hidden fixed top-16 left-0 right-0 z-50 bg-white dark:bg-[#1a1a1a] md:hidden overflow-y-auto border-t border-gray-100 dark:border-[#3d2a2a]"
    style="height: calc(100vh - 4rem); height: calc(100dvh - 4rem);"
>
    <div class="flex flex-col p-6 gap-6">
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/#program">Program</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/wykladowcy">Wykładowcy</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/#rekrutacja">Rekrutacja</a
        >
        <span class="relative text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-gray-400 dark:text-gray-600">
            Blog
            <span class="absolute -top-2 ml-2 bg-primary text-white text-[10px] font-bold px-2 py-0.5 rounded-full leading-none">wkr&oacute;tce</span>
        </span>
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="/faq">FAQ</a
        >
        <a
            class="mobile-link text-2xl font-bold border-b pb-4 border-gray-100 dark:border-gray-800 text-[#181111] dark:text-white"
            href="#kontakt">Kontakt</a
        >

        <a
            class="mt-4 bg-primary text-white py-4 rounded-xl text-xl font-bold shadow-lg shadow-primary/20 block text-center"
            href="https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PEMP-000P-NNPW2/?from=field:PEM"
            target="_blank"
            rel="noopener"
        >
            Zapisz się
        </a>
    </div>
</div>

<script is:inline>
    (function () {
        // Run immediately
        const btn = document.getElementById("mobile-menu-button");
        const menu = document.getElementById("mobile-menu");
        const links = document.querySelectorAll(".mobile-link");

        function toggleMenu() {
            if (menu) {
                menu.classList.toggle("hidden");
                document.body.classList.toggle("overflow-hidden");
            }
        }

        if (btn) {
            btn.onclick = (e) => {
                e.preventDefault();
                e.stopPropagation();
                toggleMenu();
            };
        }

        links.forEach((link) => {
            link.addEventListener("click", () => {
                if (menu) {
                    menu.classList.add("hidden");
                    document.body.classList.remove("overflow-hidden");
                }
            });
        });
    })();
</script>
