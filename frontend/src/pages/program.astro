---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProgramOverview from "../components/sections/ProgramOverview.astro";

const courseSchema = {
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "Psychologia komunikacji marketingowej i zachowań konsumenckich",
    "description":
        "Studia podyplomowe z psychologii marketingu na Politechnice Wrocławskiej: 25 przedmiotów + projekt końcowy, 206 godzin, 76 ECTS. Tryb online z egzaminem stacjonarnym.",
    "url": "https://psychologiamarketingu.edu.pl/program/",
    "inLanguage": "pl",
    "educationalCredentialAwarded": "Świadectwo ukończenia studiów podyplomowych",
    "educationalLevel": "Studia podyplomowe (Polska Rama Kwalifikacji — poziom 7)",
    "numberOfCredits": 76,
    "coursePrerequisites": "Dyplom ukończenia studiów wyższych I lub II stopnia",
    "provider": {
        "@type": "EducationalOrganization",
        "@id": "https://psychologiamarketingu.edu.pl/#organization",
        "name": "Wydział Zarządzania Politechniki Wrocławskiej",
        "url": "https://psychologiamarketingu.edu.pl/",
    },
    "offers": {
        "@type": "Offer",
        "category": "Tuition",
        "price": "7600",
        "priceCurrency": "PLN",
        "url": "https://irk.usos.pwr.edu.pl/pl/offer/PDS_2025_2026/programme/PDS-PKMP-000P-NNPW2/?from=field:PKM",
        "availability": "https://schema.org/InStock",
    },
    "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": ["online", "onsite"],
        "courseWorkload": "PT206H",
        "maximumAttendeeCapacity": 30,
    },
};

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://psychologiamarketingu.edu.pl/" },
        { "@type": "ListItem", "position": 2, "name": "Program", "item": "https://psychologiamarketingu.edu.pl/program/" },
    ],
};
---

<Layout
    title="Program studiów — Psychologia komunikacji marketingowej | PWr"
    description="Program studiów podyplomowych z psychologii marketingu na Politechnice Wrocławskiej: 25 przedmiotów + projekt, 206 h, 76 ECTS, tryb online. Pełny plan studiów i sylwetka absolwenta."
    jsonLd={[courseSchema, breadcrumbs]}
>
    <Header />
    <main id="main-content" class="flex-1">
        <ProgramOverview />
    </main>
    <Footer />
</Layout>
