---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BehavioralManifesto from "../components/sections/BehavioralManifesto.astro";

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://psychologiamarketingu.edu.pl/" },
        { "@type": "ListItem", "position": 2, "name": "Marketing behawioralny", "item": "https://psychologiamarketingu.edu.pl/marketing-behawioralny/" },
    ],
};
---

<Layout
    title="Marketing behawioralny — czym jest i jak go uczymy | PWr"
    description="Marketing behawioralny: decyzje marketingowe oparte na realnych zachowaniach konsumentów, nie na intuicji. Poznaj filozofię studiów podyplomowych Psychologia komunikacji marketingowej na PWr."
    jsonLd={breadcrumbs}
>
    <Header />
    <main id="main-content" class="flex-1">
        <BehavioralManifesto />
    </main>
    <Footer />
</Layout>
